{
  "name": "flowring",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{js,vue,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,scss,css,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "core-js": "^3.6.5",
    "register-service-worker": "^1.7.1",
    "vue": "3.0.11",
    "vue-router": "4.0.6",
    "vuex": "4.0.0",
    "vuex-persistedstate": "^4.1.0"
  },
  "devDependencies": {
    "@tabler/icons-webfont": "^2.47.0",
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-pwa": "~4.5.0",
    "@vue/cli-plugin-router": "~4.5.0",
    "@vue/cli-plugin-vuex": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "@vue/compiler-sfc": "3.0.11",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.9.4",
    "sass": "1.26.5",
    "sass-loader": "8.0.2",
    "vue-eslint-parser": "^9.4.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{scss,css,json}": [
      "prettier --write"
    ]
  }
}
